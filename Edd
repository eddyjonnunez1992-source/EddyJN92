    <div id="window-right" class="edge-window">
        <div class="panel-header">TURF STATUS</div>
        <div class="stat-row">Gnomes Active: <span class="stat-val" id="ui-gnomes">0</span></div>
        <div class="stat-row">Yard Chaos: <span class="stat-val" id="ui-chaos">0%</span></div>
        <div class="stat-row">Vandal Dollars: <span class="stat-val" id="ui-dollars">$0</span></div>
        <div style="margin-top: 20px; border-top: 1px solid #333; padding-top: 10px;">
            <div style="color: var(--neon-sec); font-weight: bold; margin-bottom: 5px;">CURRENT DIRECTIVES</div>
            <div style="font-size: 13px; color: #aaa; margin-bottom: 8px;">> Burn the "Vote for Rookies" sign</div>
            <div style="font-size: 13px; color: #aaa; margin-bottom: 8px;">> Cancel Bratwursts for Big Boys</div>
