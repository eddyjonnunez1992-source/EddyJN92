<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>OP: ROOKIE REBELLION // GNOME KINETICS</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@100;400;800&family=Bangers&family=VT323&display=swap');

        :root {
            --ui-bg: rgba(10, 15, 10, 0.85);
            --ui-border: rgba(50, 205, 50, 0.4);
            --neon-pry: #32cd32; /* Grass Green */
            --neon-sec: #ff3300; /* Fire Red */
            --neon-warn: #ffcc00; /* Dollar Gold */
            --bg-deep: #050a05;
        }

        * { box-sizing: border-box; touch-action: none; user-select: none; }
        body, html { 
            margin: 0; padding: 0; width: 100%; height: 100%; 
            background: var(--bg-deep); overflow: hidden; 
            font-family: 'JetBrains Mono', monospace; color: #fff; 
        }

        #canvas-container { position: absolute; inset: 0; z-index: 0; }

        /* Vfx overlays */
        #crt-overlay {
            position: absolute; inset: 0; pointer-events: none; z-index: 900;
            background: 
                linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.25) 50%), 
                linear-gradient(90deg, rgba(255, 0, 0, 0.03), rgba(0, 255, 0, 0.01), rgba(0, 0, 255, 0.03));
            background-size: 100% 2px, 3px 100%;
            animation: flicker 0.15s infinite; mix-blend-mode: screen;
        }
        @keyframes flicker { 0% { opacity: 0.95; } 50% { opacity: 0.85; } 100% { opacity: 0.95; } }
        
        #halftone {
            position: absolute; inset: 0;
            background-image: radial-gradient(circle, #000 8%, transparent 9%), radial-gradient(circle, #000 8%, transparent 9%);
            background-size: 12px 12px; background-position: 0 0, 6px 6px;
            opacity: 0.4; pointer-events: none; z-index: 5; mix-blend-mode: multiply;
        }

        #vignette {
            position: absolute; inset: 0; pointer-events: none; z-index: 899;
            background: radial-gradient(circle, transparent 40%, #000 130%);
        }

        #interaction-layer { position: absolute; inset: 0; z-index: 50; cursor: crosshair; }
        #interaction-layer:active { cursor: grabbing; }

        /* --- AUTO-HIDE CENTRALIZED RADIAL TOP HUD --- */
        #central-hud-wrapper {
            position: absolute; top: 10px; left: 50%; transform: translateX(-50%);
            z-index: 1000; pointer-events: auto; display: flex; flex-direction: column; align-items: center;
        }

        #hud-trigger-btn {
            width: 32px; height: 32px; background: var(--ui-bg); border: 1px solid var(--neon-pry);
            color: var(--neon-pry); font-size: 16px; border-radius: 50%; cursor: pointer;
            display: flex; align-items: center; justify-content: center; backdrop-filter: blur(10px);
            box-shadow: 0 0 10px rgba(50, 205, 50, 0.3); transition: all 0.3s; z-index: 1001;
        }

        #hud-trigger-btn:hover, #central-hud-wrapper:hover #hud-trigger-btn {
            transform: rotate(90deg) scale(1.1); background: var(--neon-pry); color: #000;
            box-shadow: 0 0 20px var(--neon-pry);
        }

        #hud-radial-ring {
            position: absolute; top: 16px; width: 180px; height: 180px;
            pointer-events: none; transform: scale(0.4) rotate(-90deg); opacity: 0;
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            display: flex; justify-content: center; align-items: center;
        }

        #central-hud-wrapper:hover #hud-radial-ring {
            transform: scale(1) rotate(0deg); opacity: 1; pointer-events: auto;
        }

        .hud-icon-btn {
            position: absolute; width: 30px; height: 30px; background: var(--ui-bg);
            border: 1px solid var(--ui-border); color: var(--neon-pry); font-family: 'Wingdings', 'JetBrains Mono', sans-serif;
            font-size: 14px; border-radius: 50%; cursor: pointer; display: flex; align-items: center; justify-content: center;
            transition: all 0.2s; box-shadow: 0 0 8px rgba(50, 205, 50, 0.2); backdrop-filter: blur(5px);
        }

        .hud-icon-btn:hover, .hud-icon-btn.active {
            background: var(--neon-pry); color: #000; box-shadow: 0 0 15px var(--neon-pry); transform: scale(1.2);
        }

        .hud-icon-btn::after {
            content: attr(data-label); position: absolute; bottom: -20px;
            font-family: 'JetBrains Mono', monospace; font-size: 8px; color: #fff;
            opacity: 0; transition: opacity 0.2s; pointer-events: none;
            background: rgba(0,0,0,0.9); padding: 3px 6px; border-radius: 2px;
            white-space: nowrap; border: 1px solid var(--ui-border); letter-spacing: 1px;
        }
        .hud-icon-btn:hover::after { opacity: 1; }

        /* Radial Slots (5 items) */
        .hud-icon-btn[data-slot="1"] { transform: translate(-75px, 0px); }
        .hud-icon-btn[data-slot="2"] { transform: translate(-45px, -60px); }
        .hud-icon-btn[data-slot="3"] { transform: translate(0px, -75px); }
        .hud-icon-btn[data-slot="4"] { transform: translate(45px, -60px); }
        .hud-icon-btn[data-slot="5"] { transform: translate(75px, 0px); }

        /* --- COLLAPSIBLE EDGE WINDOWS (L/R/U/D) --- */
        .edge-window {
            position: absolute; background: linear-gradient(135deg, rgba(5,10,5,0.95), rgba(15,25,15,0.85));
            border: 1px solid var(--ui-border); backdrop-filter: blur(12px); 
            z-index: 100; pointer-events: auto;
            transition: transform 0.5s cubic-bezier(0.075, 0.82, 0.165, 1); 
            box-shadow: 0 10px 30px rgba(0,0,0,0.8);
            font-family: 'VT323', monospace; text-transform: uppercase; font-size: 15px;
        }

        #window-left { 
            top: 50%; left: 0; transform: translateY(-50%); width: 260px; max-height: 80vh; overflow-y: auto;
            border-left: none; border-radius: 0 8px 8px 0; padding: 15px;
        }
        #window-left.hidden { transform: translate(-100%, -50%); }

        #window-right { 
            top: 50%; right: 0; transform: translateY(-50%); width: 240px; 
            border-right: none; border-radius: 8px 0 0 8px; padding: 15px;
        }
        #window-right.hidden { transform: translate(100%, -50%); }

        #window-down { 
            bottom: 0; left: 0; width: 100%; border-bottom: none; border-radius: 8px 8px 0 0;
            height: 35px; display: flex; align-items: center; overflow: hidden; border-top: 2px solid var(--neon-sec);
        }
        #window-down.hidden { transform: translateY(100%); }

        /* Scrollbar for left window */
        ::-webkit-scrollbar { width: 4px; }
        ::-webkit-scrollbar-track { background: #000; }
        ::-webkit-scrollbar-thumb { background: var(--neon-pry); }

        /* Typography & Styling */
        .panel-header { font-family: 'Bangers', cursive; font-size: 24px; color: var(--neon-pry); letter-spacing: 1px; border-bottom: 2px solid #222; padding-bottom: 5px; margin-bottom: 15px; text-shadow: 2px 2px 0px #000; }
        .dossier { background: rgba(0,0,0,0.6); border: 1px solid #333; padding: 10px; margin-bottom: 10px; border-radius: 4px; border-left: 3px solid var(--neon-pry); }
        .dossier .name { font-weight: bold; color: #fff; font-size: 16px; margin-bottom: 4px; }
        .dossier .class { color: var(--neon-warn); font-size: 12px; margin-bottom: 4px; }
        .dossier .desc { color: #aaa; font-size: 12px; line-height: 1.2; }
        
        .stat-row { display: flex; justify-content: space-between; margin-bottom: 5px; color: #ccc; }
        .stat-val { color: var(--neon-warn); font-weight: bold; }

        /* Marquee specific styling */
        #marquee-scroll {
            display: flex; white-space: nowrap; font-size: 18px; font-family: 'Bangers';
            color: var(--neon-sec); letter-spacing: 2px; position: absolute; left: 100%;
            animation: marquee 25s linear infinite; text-shadow: 1px 1px 0 #000;
        }
        @keyframes marquee { 0% { transform: translateX(0); } 100% { transform: translateX(-100%); } }

        #crosshair {
            position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
            color: rgba(255,255,255,0.2); font-size: 20px; pointer-events: none; z-index: 40;
        }

        /* --- SQUAD WALKIE-TALKIE CONSOLE --- */
        #radio-toggle-btn {
            position: absolute; bottom: 50px; left: 15px; z-index: 100;
            background: var(--ui-bg); border: 1px solid var(--neon-pry); border-radius: 5px;
            color: var(--neon-pry); font-family: 'VT323', monospace; font-size: 18px;
            padding: 8px 12px; cursor: pointer; display: flex; align-items: center; gap: 6px;
            box-shadow: 0 0 10px rgba(50, 205, 50, 0.2); transition: all 0.3s;
        }
        #radio-toggle-btn:hover {
            background: var(--neon-pry); color: #000; box-shadow: 0 0 15px var(--neon-pry);
        }

        #window-ai {
            position: absolute; bottom: 100px; left: 15px; width: 330px;
            max-height: 480px; z-index: 1000; border-radius: 8px;
            padding: 15px; display: flex; flex-direction: column; gap: 10px;
            border: 1px solid var(--neon-pry); background: linear-gradient(135deg, rgba(5,15,5,0.98), rgba(10,25,10,0.95));
            box-shadow: 0 0 25px rgba(50, 205, 50, 0.3); font-family: 'VT323', monospace;
            transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275); transform-origin: bottom left;
        }
        #window-ai.hidden { transform: scale(0); opacity: 0; pointer-events: none; }

        .radio-screen {
            background: rgba(0, 0, 0, 0.85); border: 1px solid rgba(50, 205, 50, 0.2);
            border-radius: 4px; padding: 10px; flex: 1; min-height: 180px; max-height: 220px;
            overflow-y: auto; display: flex; flex-direction: column; gap: 8px;
            box-shadow: inset 0 0 10px rgba(0,0,0,1);
        }

        .radio-msg { border-bottom: 1px dashed rgba(50, 205, 50, 0.15); padding-bottom: 5px; }
        .radio-msg .sender { font-weight: bold; font-size: 15px; letter-spacing: 0.5px; }
        .radio-msg.user .sender { color: var(--neon-warn); }
        .radio-msg.ai .sender { color: var(--neon-pry); }
        .radio-msg .text { color: #fff; font-family: 'JetBrains Mono', monospace; font-size: 11px; margin-top: 3px; line-height: 1.3; }

        .squad-selector {
            background: #000; border: 1px solid var(--ui-border); color: #fff;
            padding: 6px; font-family: 'VT323'; font-size: 16px; border-radius: 4px;
            width: 100%; outline: none; cursor: pointer;
        }

        .ai-action-row { display: flex; gap: 8px; width: 100%; }
        .ai-btn {
            flex: 1; background: rgba(50, 205, 50, 0.1); border: 1px solid var(--neon-pry);
            color: var(--neon-pry); font-family: 'VT323'; font-size: 15px; padding: 6px;
            cursor: pointer; border-radius: 4px; transition: all 0.2s; text-align: center;
        }
        .ai-btn:hover { background: var(--neon-pry); color: #000; box-shadow: 0 0 10px var(--neon-pry); }
        .ai-btn:disabled { opacity: 0.4; cursor: not-allowed; }

        .radio-input-row { display: flex; gap: 6px; }
        .radio-input {
            flex: 1; background: #000; border: 1px solid var(--ui-border);
            color: #fff; font-family: 'JetBrains Mono', monospace; font-size: 12px;
            padding: 8px; border-radius: 4px; outline: none;
        }
        .radio-send-btn {
            background: var(--neon-pry); border: none; color: #000;
            font-family: 'VT323'; font-size: 16px; padding: 0 16px; cursor: pointer;
            border-radius: 4px; transition: 0.2s; font-weight: bold;
        }
        .radio-send-btn:hover { box-shadow: 0 0 10px var(--neon-pry); }
    </style>
</head>
<body>

    <div id="halftone"></div>
    <div id="vignette"></div>
    <div id="crt-overlay"></div>
    <div id="crosshair">+</div>

    <div id="interaction-layer"></div>
    <div id="canvas-container"></div>

    <!-- RADIAL TOP CENTRAL HUD -->
    <div id="central-hud-wrapper">
        <button id="hud-trigger-btn">◈</button>
        <div id="hud-radial-ring">
            <div class="hud-icon-btn" onclick="toggleWin('window-left')" data-slot="1" data-label="DOSSIERS (L)">◧</div>
