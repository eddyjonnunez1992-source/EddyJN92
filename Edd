                });
                const mesh = new THREE.Mesh(geo, mat);
                mesh.position.set((Math.random()-0.5)*2, 6, -5 + (Math.random()-0.5)*2);
                mesh.userData = { velocity: new THREE.Vector3((Math.random()-0.5)*0.05, 0.1 + Math.random()*0.1, (Math.random()-0.5)*0.05), life: 1.0 };
