            setupInteraction() {
                this.raycaster = new THREE.Raycaster();
                this.mouse = new THREE.Vector2();
                this.dragPlane = new THREE.Plane(new THREE.Vector3(0, 1, 0), 0);
                
                this.mouseBody = new CANNON.Body({ mass: 0, type: CANNON.Body.KINEMATIC });
                this.world.addBody(this.mouseBody);
                this.mouseConstraint = null;

                const interLayer = document.getElementById('interaction-layer');
                
                const onDown = (e) => {
                    const clientX = e.touches ? e.touches[0].clientX : e.clientX;
                    const clientY = e.touches ? e.touches[0].clientY : e.clientY;
                    this.mouse.x = (clientX / window.innerWidth) * 2 - 1;
                    this.mouse.y = -(clientY / window.innerHeight) * 2 + 1;
                    
                    this.raycaster.setFromCamera(this.mouse, this.camera);
                    const intersects = this.raycaster.intersectObjects(this.scene.children, true);
                    
                    for (let i = 0; i < intersects.length; i++) {
                        let mesh = intersects[i].object;
                        // Find parent with physics body if child clicked (like hat or beard)
                        while(mesh && !mesh.userData.physicsBody && mesh.parent) {
                            mesh = mesh.parent;
                        }

                        if (mesh && mesh.userData && mesh.userData.physicsBody) {
                            const body = mesh.userData.physicsBody;
                            this.dragPlane.setFromNormalAndCoplanarPoint(
                                this.camera.getWorldDirection(new THREE.Vector3()),
                                intersects[i].point
                            );
                            
                            this.mouseBody.position.copy(intersects[i].point);
                            this.mouseConstraint = new CANNON.PointToPointConstraint(
                                body, new CANNON.Vec3(0,0,0),
                                this.mouseBody, new CANNON.Vec3(0,0,0)
                            );
                            this.world.addConstraint(this.mouseConstraint);
                            break;
                        }
                    }
                };

                const onMove = (e) => {
                    if (!this.mouseConstraint) return;
                    const clientX = e.touches ? e.touches[0].clientX : e.clientX;
                    const clientY = e.touches ? e.touches[0].clientY : e.clientY;
                    this.mouse.x = (clientX / window.innerWidth) * 2 - 1;
                    this.mouse.y = -(clientY / window.innerHeight) * 2 + 1;
                    
                    this.raycaster.setFromCamera(this.mouse, this.camera);
                    const target = new THREE.Vector3();
                    this.raycaster.ray.intersectPlane(this.dragPlane, target);
                    if(target) {
                        this.mouseBody.position.copy(target);
                        UIState.chaos += 0.1;
                        UIState.dollars += 0.5; // Farm dollars by dragging gnomes
                    }
                };

                const onUp = () => {
                    if (this.mouseConstraint) {
                        this.world.removeConstraint(this.mouseConstraint);
                        this.mouseConstraint = null;
                    }
                };

                interLayer.addEventListener('mousedown', onDown);
                interLayer.addEventListener('mousemove', onMove);
                window.addEventListener('mouseup', onUp);
                
                interLayer.addEventListener('touchstart', onDown, {passive: false});
                interLayer.addEventListener('touchmove', onMove, {passive: false});
                window.addEventListener('touchend', onUp);

                document.getElementById('btn-spawn').onclick = () => this.spawnGnome();
                document.getElementById('btn-reset').onclick = () => {
                    this.ragdolls.forEach(r => r.destroy(this));
                    this.ragdolls = [];
