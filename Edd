        </div>
    </div>

    <div id="window-down" class="edge-window">
        <div id="marquee-scroll">
            OPERATION: ROOKIE REBELLION INITIATED ///// CLICK AND DRAG TO THROW GNOMES ///// CANCEL THE PERFECT PATCH ///// BRATWURSTS CANCELLED ///// ONE MAN'S TRASH IS ANOTHER GNOME'S TREASURE ///// BURN THE MASTERPIECE ///// 
        </div>
    </div>

    <!-- Import Maps -->
    <script async src="https://unpkg.com/es-module-shims@1.8.0/dist/es-module-shims.js"></script>
    <script type="importmap">
        {
            "imports": {
                "three": "https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.module.js",
                "cannon-es": "https://unpkg.com/cannon-es@0.20.0/dist/cannon-es.js"
            }
        }
    </script>

    <script>
        function toggleWin(id) { document.getElementById(id).classList.toggle('hidden'); }
        // Start with feed hidden to maximize view
        setTimeout(() => { toggleWin('window-down'); toggleWin('window-right'); }, 100);
    </script>

    <script type="module">
        import * as THREE from 'three';
        import * as CANNON from 'cannon-es';

        const UIState = {
            gnomes: 0, chaos: 0, dollars: 0,
            update() {
                document.getElementById('ui-gnomes').innerText = this.gnomes;
                document.getElementById('ui-chaos').innerText = Math.min(100, Math.floor(this.chaos)) + '%';
                document.getElementById('ui-dollars').innerText = '$' + Math.floor(this.dollars);
            }
        };

        class Engine {
            constructor() {
                this.scene = new THREE.Scene();
                this.scene.background = new THREE.Color(0x0a141a);
                this.scene.fog = new THREE.FogExp2(0x0a141a, 0.015);
                
                this.camera = new THREE.PerspectiveCamera(55, window.innerWidth / window.innerHeight, 0.1, 1000);
                this.camera.position.set(0, 15, 35);
                this.camera.lookAt(0, 5, 0);

                this.renderer = new THREE.WebGLRenderer({ antialias: true });
                this.renderer.setSize(window.innerWidth, window.innerHeight);
                this.renderer.shadowMap.enabled = true;
                this.renderer.shadowMap.type = THREE.PCFSoftShadowMap;
                document.getElementById('canvas-container').appendChild(this.renderer.domElement);

                this.world = new CANNON.World({ gravity: new CANNON.Vec3(0, -25, 0) });
                this.world.solver.iterations = 30; 
                
                this.timeStep = 1 / 60;
                this.ragdolls = [];
                this.fireParticles = [];

                this.setupLighting();
                this.setupMaterials();
                this.generateSuburbanYard();
                this.setupInteraction();

                // Spawn initial squad
                setTimeout(() => this.spawnGnome(), 500);
                setTimeout(() => this.spawnGnome(), 1000);

                this.animate();
            }

            setupLighting() {
                this.scene.add(new THREE.AmbientLight(0x404040, 0.8)); // Subdued ambient

                const dirLight = new THREE.DirectionalLight(0xfffae6, 0.6); // Moonlight/Streetlight
                dirLight.position.set(-20, 40, 20);
                dirLight.castShadow = true;
                dirLight.shadow.mapSize.width = 2048;
                dirLight.shadow.mapSize.height = 2048;
                dirLight.shadow.camera.near = 0.5; dirLight.shadow.camera.far = 100;
                const d = 30;
                dirLight.shadow.camera.left = -d; dirLight.shadow.camera.right = d;
                dirLight.shadow.camera.top = d; dirLight.shadow.camera.bottom = -d;
                this.scene.add(dirLight);

                // Fire barrel light
                this.fireLight = new THREE.PointLight(0xff5500, 2.5, 30);
                this.fireLight.position.set(0, 6, -5);
                this.scene.add(this.fireLight);
            }

            setupMaterials() {
                this.matGrass = new THREE.MeshStandardMaterial({ color: 0x2b4f26, roughness: 1.0 });
                this.matFence = new THREE.MeshStandardMaterial({ color: 0xe0dbcd, roughness: 0.9, bumpScale: 0.05 });
                this.matWood = new THREE.MeshStandardMaterial({ color: 0x4a3219, roughness: 0.8 });
                this.matBarrel = new THREE.MeshStandardMaterial({ color: 0x3a2c24, roughness: 0.7, metalness: 0.3 });
                
                // Gnome Materials
                this.matSkin = new THREE.MeshStandardMaterial({ color: 0xffccaa, roughness: 0.5 });
                this.matBeard = new THREE.MeshStandardMaterial({ color: 0xeeeeee, roughness: 0.9 });
                this.matShirt = new THREE.MeshStandardMaterial({ color: 0x1a1a1a }); // Black hoodie
                this.matJeans = new THREE.MeshStandardMaterial({ color: 0x243447 }); // Blue jeans
                this.matHatRed = new THREE.MeshStandardMaterial({ color: 0xaa2222 }); 
                this.matHatCamo = new THREE.MeshStandardMaterial({ color: 0x4b5320 }); 

                this.physMat = new CANNON.Material('standard');
                this.world.addContactMaterial(new CANNON.ContactMaterial(this.physMat, this.physMat, { friction: 0.5, restitution: 0.2 }));
            }

            generateSuburbanYard() {
                // Grass Floor
                const floorGeo = new THREE.PlaneGeometry(100, 100);
                const floorMesh = new THREE.Mesh(floorGeo, this.matGrass);
                floorMesh.rotation.x = -Math.PI / 2;
                floorMesh.receiveShadow = true;
                this.scene.add(floorMesh);
                
                const floorBody = new CANNON.Body({ mass: 0, material: this.physMat, shape: new CANNON.Plane() });
                floorBody.quaternion.setFromEuler(-Math.PI / 2, 0, 0);
                this.world.addBody(floorBody);

                // Block Wall (Fence)
                const wallGeo = new THREE.BoxGeometry(60, 12, 2);
                const wallMesh = new THREE.Mesh(wallGeo, this.matFence);
                wallMesh.position.set(0, 6, -15);
                wallMesh.receiveShadow = true; wallMesh.castShadow = true;
                this.scene.add(wallMesh);
                
                const wallBody = new CANNON.Body({ mass: 0, material: this.physMat, shape: new CANNON.Box(new CANNON.Vec3(30, 6, 1)) });
                wallBody.position.copy(wallMesh.position);
                this.world.addBody(wallBody);

                // Trash Barrel
                const barrelGeo = new THREE.CylinderGeometry(2, 2, 6, 16);
                const barrelMesh = new THREE.Mesh(barrelGeo, this.matBarrel);
                barrelMesh.position.set(0, 3, -5);
                barrelMesh.castShadow = true; barrelMesh.receiveShadow = true;
                this.scene.add(barrelMesh);
                
                const barrelBody = new CANNON.Body({ mass: 0, material: this.physMat, shape: new CANNON.Cylinder(2, 2, 6, 16) });
                // Cylinder in cannon aligns with Z by default, need to rotate it
