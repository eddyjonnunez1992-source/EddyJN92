                    e.currentTarget.classList.toggle('active');
                };
            }

            animate() {
                requestAnimationFrame(() => this.animate());

                this.world.step(this.timeStep);

                this.ragdolls.forEach(ragdoll => ragdoll.update());
                
                if(this.props) {
                    this.props.forEach(p => {
                        p.mesh.position.copy(p.body.position);
                        p.mesh.quaternion.copy(p.body.quaternion);
                    });
                }

                this.updateFire();
                
                UIState.update();
                this.renderer.render(this.scene, this.camera);
            }
        }

        class GnomeRagdoll {
            constructor(engine, x, y, z, type='red') {
                this.engine = engine; this.scale = 1.0;
                this.bodies = []; this.meshes = []; this.constraints = [];

                const s = this.scale; 
                const headR = 0.5 * s;
                // Thicker, shorter proportions for Gnome
                const torsoSz = new CANNON.Vec3(0.7 * s, 0.7 * s, 0.5 * s);
                const armSz = new CANNON.Vec3(0.25 * s, 0.5 * s, 0.25 * s);
                const legSz = new CANNON.Vec3(0.3 * s, 0.5 * s, 0.3 * s);
                const g = 0.1 * s; // gap

                const matHat = type === 'red' ? engine.matHatRed : engine.matHatCamo;
                const matShirt = engine.matShirt;
                const matJeans = engine.matJeans;

                // Create physics bodies
                this.head = this.createHead(headR, matHat, new CANNON.Vec3(x, y + torsoSz.y + headR + g, z));
                this.torsoBody = this.createPart(new CANNON.Box(torsoSz), new THREE.BoxGeometry(torsoSz.x*2, torsoSz.y*2, torsoSz.z*2), matShirt, 5, new CANNON.Vec3(x, y, z));
                
                this.armL = this.createPart(new CANNON.Box(armSz), new THREE.BoxGeometry(armSz.x*2, armSz.y*2, armSz.z*2), matShirt, 1, new CANNON.Vec3(x - torsoSz.x - armSz.x - g, y, z));
                this.armR = this.createPart(new CANNON.Box(armSz), new THREE.BoxGeometry(armSz.x*2, armSz.y*2, armSz.z*2), matShirt, 1, new CANNON.Vec3(x + torsoSz.x + armSz.x + g, y, z));

                this.legL = this.createPart(new CANNON.Box(legSz), new THREE.BoxGeometry(legSz.x*2, legSz.y*2, legSz.z*2), matJeans, 2, new CANNON.Vec3(x - torsoSz.x/2, y - torsoSz.y - legSz.y - g, z));
                this.legR = this.createPart(new CANNON.Box(legSz), new THREE.BoxGeometry(legSz.x*2, legSz.y*2, legSz.z*2), matJeans, 2, new CANNON.Vec3(x + torsoSz.x/2, y - torsoSz.y - legSz.y - g, z));

                // Constraints (Simplified for short gnome limbs - no elbows/knees to reduce floppiness and fit proportions)
                const angle = Math.PI / 3; const twist = Math.PI / 4;

                this.connectCone(this.torsoBody, this.head, new CANNON.Vec3(0, torsoSz.y+g, 0), new CANNON.Vec3(0, -headR, 0), angle);
                this.connectCone(this.torsoBody, this.armL, new CANNON.Vec3(-torsoSz.x-g, torsoSz.y-g, 0), new CANNON.Vec3(0, armSz.y, 0), angle, twist);
                this.connectCone(this.torsoBody, this.armR, new CANNON.Vec3(torsoSz.x+g, torsoSz.y-g, 0), new CANNON.Vec3(0, armSz.y, 0), angle, twist);
                
                this.connectCone(this.torsoBody, this.legL, new CANNON.Vec3(-torsoSz.x/2, -torsoSz.y-g, 0), new CANNON.Vec3(0, legSz.y, 0), angle, twist);
                this.connectCone(this.torsoBody, this.legR, new CANNON.Vec3(torsoSz.x/2, -torsoSz.y-g, 0), new CANNON.Vec3(0, legSz.y, 0), angle, twist);

                // Add random initial torque/velocity to throw them in
                this.torsoBody.velocity.set((Math.random()-0.5)*10, 5, (Math.random()-0.5)*10);
                this.torsoBody.angularVelocity.set((Math.random()-0.5)*5, (Math.random()-0.5)*5, (Math.random()-0.5)*5);
            }

            createHead(radius, hatMat, pos) {
                const body = new CANNON.Body({ mass: 2, material: this.engine.physMat });
                body.addShape(new CANNON.Sphere(radius));
                body.position.copy(pos);
                this.engine.world.addBody(body);
                this.bodies.push(body);

                // Base Head Mesh
                const mesh = new THREE.Mesh(new THREE.SphereGeometry(radius, 16, 16), this.engine.matSkin);
                mesh.castShadow = true; 
                
                // Add Cone Hat
                const hatH = radius * 2.5;
                const hatMesh = new THREE.Mesh(new THREE.ConeGeometry(radius * 1.1, hatH, 16), hatMat);
                hatMesh.position.y = radius + hatH/2 - 0.2;
                hatMesh.castShadow = true;
                mesh.add(hatMesh);

                // Add Beard
                const beardMesh = new THREE.Mesh(new THREE.ConeGeometry(radius * 0.9, radius * 1.5, 16), this.engine.matBeard);
                beardMesh.position.set(0, -radius*0.2, radius*0.8);
                beardMesh.rotation.x = -Math.PI / 8;
                mesh.add(beardMesh);
                
                // Add shades (Sunglasses)
                const shadesGeo = new THREE.BoxGeometry(radius*1.4, radius*0.4, radius*0.2);
                const shadesMat = new THREE.MeshStandardMaterial({color: 0x000000, roughness: 0.2});
                const shadesMesh = new THREE.Mesh(shadesGeo, shadesMat);
                shadesMesh.position.set(0, radius*0.3, radius*0.9);
                mesh.add(shadesMesh);

                mesh.userData.physicsBody = body; 
                this.engine.scene.add(mesh);
                this.meshes.push({ mesh, body });
                
                return body;
            }

            createPart(shape, geometry, mat, mass, pos) {
                const body = new CANNON.Body({ mass: mass, material: this.engine.physMat, linearDamping: 0.1, angularDamping: 0.1 });
                body.addShape(shape);
                body.position.copy(pos);
                this.engine.world.addBody(body);
                this.bodies.push(body);

                const mesh = new THREE.Mesh(geometry, mat);
                mesh.castShadow = true; mesh.receiveShadow = true;
                
                // Gold chain on Torso
                if(mass === 5) {
                    const chain = new THREE.Mesh(
                        new THREE.TorusGeometry(0.4, 0.05, 8, 24), 
                        new THREE.MeshStandardMaterial({color: 0xffcc00, metalness: 0.8, roughness: 0.2})
                    );
                    chain.position.set(0, 0.2, 0.5);
                    chain.rotation.x = Math.PI / 4;
                    mesh.add(chain);
                }

                mesh.userData.physicsBody = body; 
                this.engine.scene.add(mesh);
                this.meshes.push({ mesh, body });
                
                return body;
            }

            connectCone(bodyA, bodyB, pivotA, pivotB, angle, twist=Math.PI/8) {
                const constraint = new CANNON.ConeTwistConstraint(bodyA, bodyB, {
                    pivotA: pivotA, pivotB: pivotB, axisA: CANNON.Vec3.UNIT_Y, axisB: CANNON.Vec3.UNIT_Y, angle: angle, twistAngle: twist
                });
                this.engine.world.addConstraint(constraint);
                this.constraints.push(constraint);
            }

            update() {
                this.meshes.forEach(m => { m.mesh.position.copy(m.body.position); m.mesh.quaternion.copy(m.body.quaternion); });
            }
            
            destroy(engine) {
                this.constraints.forEach(c => engine.world.removeConstraint(c));
                this.bodies.forEach(b => engine.world.removeBody(b));
                this.meshes.forEach(m => engine.scene.remove(m.mesh));
            }
        }

        window.onload = () => { window.app = new Engine(); };
        window.addEventListener('resize', () => {
            if(window.app) {
                window.app.renderer.setSize(window.innerWidth, window.innerHeight);
                window.app.camera.aspect = window.innerWidth / window.innerHeight;
                window.app.camera.updateProjectionMatrix();
            }
        });
