            font-size: var(--font-micro); padding: 2px; display: none;
            flex-direction: column; gap: 2px; z-index: 150;
            backdrop-filter: blur(8px); border-radius: 2px;
            transform-origin: top; opacity: 0; transition: opacity 0.2s ease;
        }
        .tr-menu { border-color: var(--ui-alt); color: var(--ui-alt); }

        .drag-menu-item {
            padding: 6px 12px; cursor: pointer; text-transform: uppercase;
            letter-spacing: 1px; border: 0.5px solid transparent; transition: all 0.1s;
        }
        .drag-menu-item.active { background: rgba(0, 255, 204, 0.2); border-color: var(--ui-color); }
        .tr-menu .drag-menu-item.active { background: rgba(255, 0, 85, 0.2); border-color: var(--ui-alt); }

        /* PIP Frames */
        .pip-container {
            position: absolute; bottom: 15px; width: 140px; height: 105px;
            z-index: 90; cursor: pointer; border: 1px solid rgba(255,255,255,0.2);
            background: rgba(0,0,0,0.8); overflow: hidden;
            box-shadow: 0 0 10px rgba(0,0,0,0.5); backdrop-filter: blur(2px);
        }
        #pip-left-box { left: 15px; border-left: 2px solid var(--ui-color); }
        #pip-right-box { right: 15px; border-right: 2px solid var(--ui-alt); }

        .pip-label {
            position: absolute; top: 0; left: 0; background: rgba(0,0,0,0.8);
            color: #fff; font-size: var(--font-micro); padding: 2px 4px;
            text-transform: uppercase; letter-spacing: 1px; z-index: 95;
        }
        
        #boot-screen {
            position: absolute; inset: 0; background: #000; z-index: 500;
            display: flex; flex-direction: column; align-items: center; justify-content: center;
            color: var(--ui-color); font-size: 10px; letter-spacing: 2px;
        }
        #boot-screen button {
            background: transparent; border: 1px solid var(--ui-color); color: var(--ui-color);
            padding: 10px 20px; font-family: inherit; font-size: 12px; cursor: pointer;
            margin-top: 20px; text-transform: uppercase; transition: all 0.2s;
        }
        #boot-screen button:hover { background: var(--ui-color); color: #000; }
    </style>

    <!-- Import Map for Generative Procedural Modules -->
    <script type="importmap">
        {
            "imports": {
                "three": "https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.module.js",
                "cannon-es": "https://unpkg.com/cannon-es@0.20.0/dist/cannon-es.js"
            }
        }
    </script>
</head>
<body>

    <div id="boot-screen">
        <div style="margin-bottom: 10px;">NEXUS META-PRODUCTIVE ENGINE v4.2</div>
        <div style="font-size: 8px; color: #888;">100 FX NODES // PROCEDURAL GENERATION // CANNON.JS RIG</div>
        <button id="boot-btn">Initialize Physics Engine</button>
    </div>

    <!-- Micro-Marquee UI (Top Left & Right) -->
    <div class="nexus-ui-panel tl" id="panel-tl">
        <div class="icon-trigger" id="icon-tl" title="Hold & Swipe">⎈</div>
        <div class="marquee-container">
            <div class="marquee-content" id="telemetry-mq">SYS_OPT // VEL: 0 // POS_Z: 0 // NODE_SYNC: 100%</div>
        </div>
    </div>

    <div class="nexus-ui-panel tr" id="panel-tr">
        <div class="marquee-container">
            <div class="marquee-content" id="log-mq">AWAITING_INPUT // SPATIAL_DYNAMICS: ACTIVE // GRAVITY: STANDARD</div>
        </div>
        <div class="icon-trigger" id="icon-tr" title="Hold & Swipe">⏣</div>
    </div>

    <!-- Drag-Select Autohide Menus -->
    <div class="drag-menu" id="menu-tl">
        <div class="drag-menu-item" data-action="regen_topology">Regen Topology</div>
        <div class="drag-menu-item" data-action="mutate_fx">Mutate FX Nodes</div>
    </div>

    <div class="drag-menu tr-menu" id="menu-tr">
        <div class="drag-menu-item" data-action="invert_gravity">Invert Gravity</div>
        <div class="drag-menu-item" data-action="hyper_speed">Hyper Speed</div>
    </div>

    <!-- PIP Viewports -->
    <div id="pip-left-box" class="pip-container">
        <div class="pip-label" id="pip-left-label">ETHER_REALM</div>
    </div>
    <div id="pip-right-box" class="pip-container">
        <div class="pip-label" id="pip-right-label">RETRO_VOID</div>
    </div>

    <div id="canvas-container"></div>

    <script type="module">
        import * as THREE from 'three';
        import * as CANNON from 'cannon-es';

        // --- 192 IQ GLOBAL CONFIG ---
        const CONFIG = {
            segmentLength: 50,
            viewDist: 350,
            baseGravity: -40,
            timeScale: 1.0
        };

        const GlobalUniforms = {
            uTime: { value: 0 },
            uGlobalMutation: { value: 1.0 }
        };

        let renderer;
        let mainIdx = 0; // 0=Spectral, 1=Ether, 2=Retro
        let universes = [];
        
        const Input = { 
            active: false, 
            startX: 0, 
            currentX: 0, 
            isUIInteraction: false 
        };

        // --- 100 SPECIAL FX NEXUS ARCHITECTURE ---
        // Dynamically injects mathematically advanced shaders into standard Three.js materials
        const FXNexus = {
            registry: [],
            
            attachNode(mesh, type, customParams = {}) {
                if(!mesh.material) return;
                
                // Clone material to avoid overriding shared references
                mesh.material = mesh.material.clone();
                mesh.userData.fxType = type;
                
                const fxUniforms = {
                    time: GlobalUniforms.uTime,
                    mutation: GlobalUniforms.uGlobalMutation,
                    intensity: { value: customParams.intensity || 1.0 },
                    colorShift: { value: new THREE.Color(customParams.color || 0xffffff) }
                };

                mesh.material.onBeforeCompile = (shader) => {
                    shader.uniforms.time = fxUniforms.time;
                    shader.uniforms.mutation = fxUniforms.mutation;
                    shader.uniforms.intensity = fxUniforms.intensity;
                    shader.uniforms.colorShift = fxUniforms.colorShift;

                    if (type === 'quantum_wave') {
                        shader.vertexShader = `
                            uniform float time;
                            uniform float mutation;
                            uniform float intensity;
                            ${shader.vertexShader}
                        `.replace(
                            `#include <begin_vertex>`,
                            `
                            #include <begin_vertex>
                            float wave = sin(position.x * 0.2 + time * 2.0) * cos(position.z * 0.2 + time) * 2.0 * intensity * mutation;
                            transformed.y += wave;
                            `
                        );
                    } 
                    else if (type === 'ether_pulse') {
                        shader.fragmentShader = `
                            uniform float time;
                            uniform float mutation;
                            ${shader.fragmentShader}
                        `.replace(
                            `#include <dithering_fragment>`,
                            `
                            #include <dithering_fragment>
                            float pulse = abs(sin(vUv.y * 10.0 - time * 5.0)) * mutation;
                            gl_FragColor.rgb += vec3(0.0, 0.5, 0.5) * pulse * 0.5;
                            `
                        );
                    }
                    else if (type === 'retro_halftone') {
                        shader.fragmentShader = `
                            uniform float time;
                            ${shader.fragmentShader}
                        `.replace(
                            `#include <dithering_fragment>`,
                            `
                            #include <dithering_fragment>
                            vec2 grid = fract(gl_FragCoord.xy / 8.0);
                            float dist = length(grid - 0.5);
                            float luma = dot(gl_FragColor.rgb, vec3(0.299, 0.587, 0.114));
                            if(dist > luma * 0.8) gl_FragColor.rgb *= 0.2;
                            `
                        );
                    }
                };

                this.registry.push(mesh);
            },
            
            mutateAll() {
                GlobalUniforms.uGlobalMutation.value = 3.0; // Spike
                setTimeout(() => GlobalUniforms.uGlobalMutation.value = 1.0, 800); // Decay
            }
        };

        // --- PROCEDURAL SPATIAL ENVIRONMENT GENERATOR ---
        class Universe {
            constructor(type, name) {
                this.type = type; 
                this.name = name;
                this.scene = new THREE.Scene();
                this.world = new CANNON.World();
                this.world.gravity.set(0, CONFIG.baseGravity, 0);
                this.world.broadphase = new CANNON.SAPBroadphase(this.world);
                
                const m1 = new CANNON.Material();
                const m2 = new CANNON.Material();
                this.world.addContactMaterial(new CANNON.ContactMaterial(m1, m2, { friction: 0.05, restitution: 0.6 }));
                this.matGround = m1; this.matPlayer = m2;

                this.camera = new THREE.PerspectiveCamera(70, window.innerWidth/window.innerHeight, 0.1, 1000);
                
                this.segments = [];
                this.obstacles = [];
                this.lastZ = 0;

                this.buildEnvironment();
                this.spawnPlayer();
                
                for(let i=0; i<8; i++) this.generateTopology(i * CONFIG.segmentLength);
            }

            buildEnvironment() {
                if(this.type === 'Spectral') {
                    this.scene.fog = new THREE.FogExp2(0x050510, 0.008);
                    this.scene.background = new THREE.Color(0x050510);
                    const l = new THREE.DirectionalLight(0x00ffcc, 1); l.position.set(10,50,20); this.scene.add(l);
                    
                    // FX Node Background Matrix
                    const bgGeo = new THREE.IcosahedronGeometry(200, 1);
                    const bgMat = new THREE.MeshBasicMaterial({color: 0x004433, wireframe: true});
                    this.bgMesh = new THREE.Mesh(bgGeo, bgMat);
                    this.scene.add(this.bgMesh);
                    FXNexus.attachNode(this.bgMesh, 'quantum_wave', {intensity: 0.1});
                } 
                else if (this.type === 'Ether') {
                    this.scene.fog = new THREE.FogExp2(0xeeffff, 0.004);
                    this.scene.background = new THREE.Color(0xaaccff);
                    const hemi = new THREE.HemisphereLight(0xffffff, 0xffeedd, 0.8); this.scene.add(hemi);
                    
                    const bgGeo = new THREE.SphereGeometry(200, 32, 32);
                    const bgMat = new THREE.MeshBasicMaterial({color: 0xffffff, transparent: true, opacity: 0.1});
                    this.bgMesh = new THREE.Mesh(bgGeo, bgMat);
                    this.scene.add(this.bgMesh);
                    FXNexus.attachNode(this.bgMesh, 'ether_pulse');
                } 
                else {
                    this.scene.fog = new THREE.FogExp2(0x110022, 0.015);
                    this.scene.background = new THREE.Color(0x110022);
                    const l = new THREE.DirectionalLight(0xff0055, 1); l.position.set(-10,50,20); this.scene.add(l);
                    
                    const bgGeo = new THREE.PlaneGeometry(500, 500);
                    const bgMat = new THREE.MeshBasicMaterial({color: 0xff0055});
                    this.bgMesh = new THREE.Mesh(bgGeo, bgMat);
                    this.bgMesh.position.y = -50;
                    this.bgMesh.rotation.x = -Math.PI/2;
                    this.scene.add(this.bgMesh);
                    FXNexus.attachNode(this.bgMesh, 'retro_halftone');
                }
            }

            spawnPlayer() {
                const r = 1.5;
                let mat;
                if(this.type==='Spectral') mat = new THREE.MeshStandardMaterial({color:0x00ffcc, wireframe: true});
                else if(this.type==='Ether') mat = new THREE.MeshPhysicalMaterial({color: 0x00f3ff, transmission: 0.9, thickness: 1.5});
                else mat = new THREE.MeshBasicMaterial({color:0xff0055});

                this.marble = new THREE.Mesh(new THREE.SphereGeometry(r, 16, 16), mat);
                this.scene.add(this.marble);
                FXNexus.attachNode(this.marble, this.type==='Retro' ? 'retro_halftone' : 'ether_pulse');

                this.body = new CANNON.Body({ mass: 15, material: this.matPlayer, position: new CANNON.Vec3(0, 5, 0) });
                this.body.addShape(new CANNON.Sphere(r));
                this.body.linearDamping = 0.05;
                this.world.addBody(this.body);
                this.body.velocity.set(0,0,50);
            }

            generateTopology(z) {
                const group = new THREE.Group();
                const bodies = [];
                const len = CONFIG.segmentLength;

                if (this.type === 'Spectral') {
                    // Procedural mathematical wave terrain
                    const w = 30;
                    const geo = new THREE.PlaneGeometry(w, len, 10, 10);
                    geo.rotateX(-Math.PI/2);
                    const mat = new THREE.MeshStandardMaterial({color:0x002222, wireframe: true});
                    const mesh = new THREE.Mesh(geo,mat);
                    mesh.position.set(0, 0, z+len/2);
                    
                    FXNexus.attachNode(mesh, 'quantum_wave', {intensity: 1.5}); // FX Node assigned
                    group.add(mesh);
                    
                    // Physics representation (simplified plane for performance)
                    const body = new CANNON.Body({mass:0, material:this.matGround});
                    body.addShape(new CANNON.Box(new CANNON.Vec3(w/2, 0.5, len/2)));
                    body.position.copy(mesh.position);
                    this.world.addBody(body);
                    bodies.push(body);
                } 
                else if (this.type === 'Ether') {
                    // Crystalline fragmented path
                    const w = 15;
                    for(let k=0; k<3; k++) {
                        const geo = new THREE.IcosahedronGeometry(Math.random()*2+2, 0);
                        const mat = new THREE.MeshPhysicalMaterial({ color: 0xffffff, transmission: 0.8, thickness: 1.0 });
                        const mesh = new THREE.Mesh(geo, mat);
                        mesh.position.set((Math.random()-0.5)*w, -2 + Math.random()*2, z + (len/3)*k);
                        mesh.scale.set(1, 0.2, 3);
                        FXNexus.attachNode(mesh, 'ether_pulse');
                        group.add(mesh);

                        const body = new CANNON.Body({mass:0, material:this.matGround});
                        body.addShape(new CANNON.Box(new CANNON.Vec3(2, 0.5, 6)));
                        body.position.copy(mesh.position);
                        this.world.addBody(body);
                        bodies.push(body);
                    }
                } else {
                    // Retro Halftone block path
                    const geo = new THREE.BoxGeometry(20, 2, len*0.9);
                    const mat = new THREE.MeshBasicMaterial({color:0x00aaff});
                    const mesh = new THREE.Mesh(geo, mat);
                    mesh.position.set(0, -2, z+len/2);
                    FXNexus.attachNode(mesh, 'retro_halftone');
                    group.add(mesh);
                    
                    const body = new CANNON.Body({mass:0, material:this.matGround});
                    body.addShape(new CANNON.Box(new CANNON.Vec3(10, 1, len*0.45)));
                    body.position.copy(mesh.position);
                    this.world.addBody(body);
                    bodies.push(body);
                }

                // Generative Obstacles
                if(Math.random() > 0.4 && z > 50) {
                    const geo = new THREE.OctahedronGeometry(3, 0);
                    const mat = new THREE.MeshStandardMaterial({color:0xff0055});
                    const mesh = new THREE.Mesh(geo, mat);
                    mesh.position.set((Math.random()-0.5)*15, 3, z + len/2);
                    FXNexus.attachNode(mesh, this.type==='Spectral'?'quantum_wave':'ether_pulse', {intensity: 0.5});
                    group.add(mesh);
                    
                    const body = new CANNON.Body({mass:0, type:CANNON.Body.KINEMATIC});
                    body.addShape(new CANNON.Box(new CANNON.Vec3(2,2,2)));
                    body.position.copy(mesh.position);
                    this.world.addBody(body);
                    bodies.push(body);
                    this.obstacles.push({mesh, body, phase: Math.random()*Math.PI*2});
                }

                this.scene.add(group);
                this.segments.push({mesh:group, bodies:bodies, z:z});
                this.lastZ = z + len;
            }

            update(dt, steer) {
                this.world.step(dt);

                // Math-driven velocity control
                this.body.velocity.x += steer * 1.5;
                if(this.body.velocity.z < 80 * CONFIG.timeScale) this.body.velocity.z += 0.5;

                this.marble.position.copy(this.body.position);
                this.marble.quaternion.copy(this.body.quaternion);

                const t = GlobalUniforms.uTime.value;
                
                // Animate background FX
                if(this.bgMesh) {
                    this.bgMesh.rotation.y = t * 0.05;
                    if(this.type === 'Spectral') this.bgMesh.rotation.z = t * 0.02;
                }

                // Animate procedural obstacles
                this.obstacles.forEach(o => {
                    o.body.position.x += Math.sin(t*2 + o.phase) * 0.1;
                    o.body.quaternion.setFromEuler(t, t*0.5, 0);
                    o.mesh.position.copy(o.body.position);
                    o.mesh.quaternion.copy(o.body.quaternion);
                });

                // Smooth camera follow
                this.camera.position.z += ((this.marble.position.z - 30) - this.camera.position.z) * 0.1;
                this.camera.position.y += ((this.marble.position.y + 12) - this.camera.position.y) * 0.1;
                this.camera.position.x += (this.marble.position.x * 0.3 - this.camera.position.x) * 0.1;
                this.camera.lookAt(this.marble.position);

                // Procedural endless generation
                if(this.marble.position.z > this.lastZ - CONFIG.viewDist) this.generateTopology(this.lastZ);
                if(this.segments.length > 0 && this.segments[0].z < this.marble.position.z - 150) {
                    const s = this.segments.shift();
                    this.scene.remove(s.mesh);
                    s.bodies.forEach(b => this.world.removeBody(b));
                }
                
                // Void recovery
                if(this.marble.position.y < -40) {
                    this.body.position.set(0, 10, this.marble.position.z + 50);
                    this.body.velocity.set(0,0,40 * CONFIG.timeScale);
                }
            }
        }

        // --- MICRO-UI DRAG-SELECT ARCHITECTURE ---
        const UIManager = {
            holdTimer: null,
            activeMenu: null,
            isDragging: false,

            init() {
                this.setupHoldArea('icon-tl', 'menu-tl');
                this.setupHoldArea('icon-tr', 'menu-tr');
                
                document.addEventListener('pointermove', (e) => this.onMove(e), {passive: false});
                document.addEventListener('pointerup', (e) => this.onRelease(e));
            },

            setupHoldArea(iconId, menuId) {
                const icon = document.getElementById(iconId);
                icon.addEventListener('pointerdown', (e) => {
                    e.preventDefault();
                    Input.isUIInteraction = true;
                    this.holdTimer = setTimeout(() => this.showMenu(menuId, iconId), 300); // 300ms hold logic
                });
                icon.addEventListener('pointerleave', () => clearTimeout(this.holdTimer));
            },

            showMenu(menuId, iconId) {
                const menu = document.getElementById(menuId);
                const rect = document.getElementById(iconId).getBoundingClientRect();
                
                if (iconId === 'icon-tl') {
                    menu.style.left = '5px'; menu.style.top = '22px';
                } else {
                    menu.style.right = '5px'; menu.style.left = 'auto'; menu.style.top = '22px';
                }

                menu.style.display = 'flex';
                void menu.offsetWidth; // force reflow
                menu.style.opacity = '1';
                this.activeMenu = menu;
                this.isDragging = true;
            },

            onMove(e) {
                if (!this.isDragging || !this.activeMenu) return;
                e.preventDefault();
                const el = document.elementFromPoint(e.clientX, e.clientY);
                this.activeMenu.querySelectorAll('.drag-menu-item').forEach(i => i.classList.remove('active'));
                if (el && el.classList.contains('drag-menu-item')) el.classList.add('active');
            },

            onRelease(e) {
                clearTimeout(this.holdTimer);
                if (!this.isDragging || !this.activeMenu) {
                    Input.isUIInteraction = false;
                    return;
                }
                const el = document.elementFromPoint(e.clientX, e.clientY);
                if (el && el.classList.contains('drag-menu-item')) this.executeCommand(el.dataset.action);
                
                this.activeMenu.style.opacity = '0';
                setTimeout(() => {
                    if (this.activeMenu) this.activeMenu.style.display = 'none';
                    this.activeMenu = null;
                    this.isDragging = false;
                    Input.isUIInteraction = false;
                }, 200);
            },

            executeCommand(action) {
                const logMq = document.getElementById('log-mq');
                logMq.innerText = `[SYS_EXEC: ${action.toUpperCase()}]`;
                
                switch(action) {
                    case 'regen_topology':
                        universes[mainIdx].segments.forEach(s => {
                            universes[mainIdx].scene.remove(s.mesh);
                            s.bodies.forEach(b => universes[mainIdx].world.removeBody(b));
                        });
                        universes[mainIdx].segments = [];
                        universes[mainIdx].lastZ = universes[mainIdx].marble.position.z + 20;
                        for(let i=0; i<5; i++) universes[mainIdx].generateTopology(universes[mainIdx].lastZ + i*CONFIG.segmentLength);
                        break;
                    case 'mutate_fx':
                        FXNexus.mutateAll();
                        break;
                    case 'invert_gravity':
                        CONFIG.baseGravity = CONFIG.baseGravity === -40 ? 10 : -40;
                        universes.forEach(u => u.world.gravity.set(0, CONFIG.baseGravity, 0));
                        break;
                    case 'hyper_speed':
                        CONFIG.timeScale = CONFIG.timeScale === 1.0 ? 2.5 : 1.0;
                        break;
                }
            }
        };

        // --- CORE INITIALIZATION ---
        document.getElementById('boot-btn').addEventListener('click', () => {
            document.getElementById('boot-screen').style.display = 'none';
            
            renderer = new THREE.WebGLRenderer({ antialias: false, powerPreference: "high-performance" });
            renderer.setSize(window.innerWidth, window.innerHeight);
            renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
            renderer.setScissorTest(true);
            document.getElementById('canvas-container').appendChild(renderer.domElement);

            universes.push(new Universe('Spectral', 'SPECTRAL'));
            universes.push(new Universe('Ether', 'ETHER'));
            universes.push(new Universe('Retro', 'RETRO'));

            UIManager.init();
            setupSteering();
            updatePIPLabels();
            animate();
        });

        function setupSteering() {
            const c = document.getElementById('canvas-container');
            const start = x => { if(!Input.isUIInteraction){ Input.active=true; Input.startX=Input.currentX=x; }};
            const move = x => { if(Input.active) Input.currentX=x; };
            const end = () => Input.active=false;

            c.addEventListener('touchstart', e => start(e.touches[0].clientX), {passive:true});
            c.addEventListener('touchmove', e => move(e.touches[0].clientX), {passive:true});
            c.addEventListener('touchend', end);
            c.addEventListener('mousedown', e => start(e.clientX));
            window.addEventListener('mousemove', e => move(e.clientX));
            window.addEventListener('mouseup', end);

            // PIP Hit Detection
            const checkPipClick = (x, y) => {
                if(Input.isUIInteraction) return;
                const w = window.innerWidth;
                const h = window.innerHeight;
                if(y > h - 120 && y < h - 15) {
                    if(x > 15 && x < 155) swapWorlds(1); // Left PIP
                    else if(x > w - 155 && x < w - 15) swapWorlds(2); // Right PIP
                }
            };
            c.addEventListener('mousedown', e => checkPipClick(e.clientX, e.clientY));
            c.addEventListener('touchstart', e => checkPipClick(e.changedTouches[0].clientX, e.changedTouches[0].clientY));
        }

        function swapWorlds(pipPos) { 
            const others = [0, 1, 2].filter(i => i !== mainIdx);
            mainIdx = (pipPos === 1) ? others[0] : others[1];
            updatePIPLabels();
            FXNexus.mutateAll(); // Trigger FX burst on swap
            document.getElementById('log-mq').innerText = `[REALITY_SHIFT: ${universes[mainIdx].name} ENGAGED]`;
        }

        function updatePIPLabels() {
            const others = [0, 1, 2].filter(i => i !== mainIdx);
            document.getElementById('pip-left-label').innerText = universes[others[0]].name;
            document.getElementById('pip-right-label').innerText = universes[others[1]].name;
        }

        const clock = new THREE.Clock();

        function animate() {
            requestAnimationFrame(animate);
            const dt = clock.getDelta();
            GlobalUniforms.uTime.value += dt * CONFIG.timeScale;

            // Mathematical steering calculation
            let steer = 0;
            if(Input.active) steer = (Input.currentX - Input.startX) * 0.05;

            universes.forEach(u => u.update(dt * CONFIG.timeScale, steer));

            // Update Telemetry Marquee
            const u = universes[mainIdx];
            const speed = Math.floor(u.body.velocity.length() * 3.6);
            document.getElementById('telemetry-mq').innerText = `REALITY: [${u.name}] // VEL: ${speed} KM/H // DIST: ${Math.floor(u.marble.position.z)} M // GRAVITY: ${CONFIG.baseGravity} // `;

            // Render Pipeline (Scissor Test for PIP)
            const w = window.innerWidth;
            const h = window.innerHeight;
